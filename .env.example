# Copy this file to .env and fill in real values before running ./deploy.sh
# Never commit .env or .env.testnet — both are excluded in .gitignore.

# Stellar secret key (S...) used to submit the deploy transactions and pay
# their fees. Needs to hold enough XLM to cover deployment on the target
# network.
DEPLOYER_SECRET=S...

# Stellar public key (G...) granted admin rights on both contracts at
# initialize time — the only address that can trigger release_payment,
# cancel_campaign, and assign_arbiter, and the address platform fees are
# paid to.
ADMIN_ADDRESS=G...

# Stellar secret key (S...) matching ADMIN_ADDRESS, used to sign the
# initialize call on both contracts.
ADMIN_SECRET=S...

# Platform fee in basis points, deducted from each creator payout in
# campaign-escrow::release_payment and transferred to ADMIN_ADDRESS.
# 50 = 0.5%. Must be between 0 and 10000 inclusive.
FEE_BPS=50

# Network to deploy to. One of: testnet, futurenet, mainnet.
STELLAR_NETWORK=testnet
